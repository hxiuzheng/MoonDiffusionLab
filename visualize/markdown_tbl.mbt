///|
/// Markdown 统计表格生成器：对比多种采样器性能
pub fn generate_markdown_report(
  title? : String = "Diffusion Sampler Metrics",
  headers : Array[String],
  rows : Array[Array[String]],
) -> String {
  let mut md = "### " + title + "\n\n"

  md += "| " + headers.join(" | ") + " |\n"

  let seps = Array::make(headers.length(), "---")
  md += "| " + seps.join(" | ") + " |\n"

  for i in 0..<rows.length() {
    md += "| " + rows[i].join(" | ") + " |\n"
  }

  md += "\n*Generated by MoonDiffusionLab*\n"
  md
}
